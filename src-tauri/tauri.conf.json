{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Live-MR-Manager",
  "version": "0.6.2",
  "identifier": "com.autumncolor77.live-mr-manager",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Live-MR-Manager",
        "width": 1200,
        "height": 750,
        "minWidth": 1160,
        "minHeight": 700,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "scope": [
          "$APPDATA/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": [
      "resources/*",
      "resources/libs/*.dll"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
